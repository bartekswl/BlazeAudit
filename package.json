{
  "name": "blazeaudit",
  "productName": "BlazeAudit",
  "version": "0.0.0",
  "description": "Offline fire-inspection documentation desktop app by SubraLab.",
  "author": "SubraLab",
  "license": "SEE LICENSE IN README.md",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "engines": {
    "node": ">=20"
